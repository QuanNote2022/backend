{
  "info": {
    "name": "矿物识别系统 API",
    "description": "矿物识别系统后端接口测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. 认证模块",
      "item": [
        {
          "name": "用户注册",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"123456\",\n  \"email\": \"test@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "用户登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "用户登出",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "2. 用户模块",
      "item": [
        {
          "name": "获取用户信息",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["user", "profile"]
            }
          }
        },
        {
          "name": "更新用户信息",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickname\": \"测试用户\",\n  \"avatar\": \"https://example.com/avatar.jpg\",\n  \"email\": \"newemail@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["user", "profile"]
            }
          }
        },
        {
          "name": "修改密码",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"123456\",\n  \"newPassword\": \"new123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/password",
              "host": ["{{baseUrl}}"],
              "path": ["user", "password"]
            }
          }
        }
      ]
    },
    {
      "name": "3. 矿物识别模块",
      "item": [
        {
          "name": "矿物识别",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "/path/to/your/image.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/mineral/detect",
              "host": ["{{baseUrl}}"],
              "path": ["mineral", "detect"]
            }
          }
        },
        {
          "name": "获取识别详情",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/mineral/detect/{{detectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["mineral", "detect", "{{detectId}}"]
            }
          }
        },
        {
          "name": "获取矿物分类",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/mineral/categories",
              "host": ["{{baseUrl}}"],
              "path": ["mineral", "categories"]
            }
          }
        },
        {
          "name": "获取矿物信息",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/mineral/info/石英",
              "host": ["{{baseUrl}}"],
              "path": ["mineral", "info", "石英"]
            }
          }
        }
      ]
    },
    {
      "name": "4. 聊天会话模块",
      "item": [
        {
          "name": "创建聊天会话",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mineralName\": \"石英\",\n  \"detectId\": \"detect123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat/session",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "session"]
            }
          }
        },
        {
          "name": "获取会话列表",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/sessions?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "sessions"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "获取会话消息",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/session/{{sessionId}}/messages",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "session", "{{sessionId}}", "messages"]
            }
          }
        },
        {
          "name": "发送消息 (SSE)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"石英的硬度是多少？\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat/session/{{sessionId}}/send",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "session", "{{sessionId}}", "send"]
            }
          }
        },
        {
          "name": "删除会话",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/session/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "session", "{{sessionId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "5. 历史记录模块",
      "item": [
        {
          "name": "获取识别历史",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/history/detections?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["history", "detections"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                },
                {
                  "key": "keyword",
                  "value": "石英",
                  "disabled": true
                },
                {
                  "key": "startDate",
                  "value": "2024-01-01",
                  "disabled": true
                },
                {
                  "key": "endDate",
                  "value": "2024-12-31",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "删除识别记录",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/history/detections/{{detectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["history", "detections", "{{detectId}}"]
            }
          }
        },
        {
          "name": "获取聊天历史",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/history/chats?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["history", "chats"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "6. 统计模块",
      "item": [
        {
          "name": "获取统计概览",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/stats/overview",
              "host": ["{{baseUrl}}"],
              "path": ["stats", "overview"]
            }
          }
        },
        {
          "name": "获取矿物识别频率",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/stats/mineral-frequency?days=30",
              "host": ["{{baseUrl}}"],
              "path": ["stats", "mineral-frequency"],
              "query": [
                {
                  "key": "days",
                  "value": "30"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
